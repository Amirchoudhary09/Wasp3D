// WAIT GPU


void WaitForGPU()/* wait for window for cpu and gpu  work same place */
{
    fenceValue++; /* fencevalue increase++*/

    commandQueue->Signal(
        fence.Get(),
        fenceValue);/*  if gpu work till fencevalue than update fence value */

    if (fence->GetCompletedValue() < fenceValue)/* check fence value < fencevalue  if true dont say for cpu to write*/
    {
        fence->SetEventOnCompletion( /* set event  call  to gpu work */
            fenceValue,
            fenceEvent);

        WaitForSingleObject(/* sleep/wait  cpu until  fencevalue  dont equal */
            fenceEvent,
            INFINITE);
    }

    frameIndex =
        swapChain->GetCurrentBackBufferIndex();
}


